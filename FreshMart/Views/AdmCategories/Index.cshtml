@model IEnumerable<FreshMart.Models.Category>

@{
    ViewData["Title"] = "Category Management";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Category Management</h2>
            <p class="text-muted mb-0">
                Manage all product categories of FreshMart.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle me-1"></i>
            Add New Category
        </a>
    </div>

    <!-- Category Table Card -->
    <div class="card border-0 shadow-lg rounded-4">
        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-dark">
                        <tr>
                            <th>Image</th>
                            <th>Category Name</th>
                            <th>Category Details</th>
                            <th>Status</th>
                            <th width="220">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- Category Image -->
                                <td>
                                    <img src="~/DataFiles/@item.CategoryImage"
                                         alt="@item.CategoryName"
                                         class="rounded-3 border"
                                         width="80"
                                         height="80"
                                         style="object-fit:cover;" />
                                </td>

                                <!-- Category Name -->
                                <td class="fw-semibold text-dark">
                                    @item.CategoryName
                                </td>

                                <!-- Category Details -->
                                <td class="text-muted">
                                    @item.CategoryDetails
                                </td>

                                <!-- Category Status -->
                                <td>
                                    @if (item.CategoryStatus == "Active")
                                    {
                                        <span class="badge bg-success px-3 py-2">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-3 py-2">
                                            Inactive
                                        </span>
                                    }
                                </td>

                                <!-- Action Buttons -->
                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a asp-action="Edit"
                                               asp-route-id="@item.CategoryId"
                                               class="btn btn-sm btn-warning text-white">
                                            <i class="bi bi-pencil-square"></i>
                                            Edit
                                        </a>

                                        <a asp-action="Details"
                                               asp-route-id="@item.CategoryId"
                                               class="btn btn-sm btn-info text-white">
                                            <i class="bi bi-eye"></i>
                                            Details
                                        </a>

                                        <a asp-action="Delete"
                                               asp-route-id="@item.CategoryId"
                                               class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                            Delete
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

</div>