@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="mb-1">
                <i class="fas fa-tachometer-alt text-primary"></i> Admin Dashboard
            </h1>
            <small class="text-muted">Welcome back! Here's what's happening in your store.</small>
        </div>
    </div>

    <!-- Key Metrics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-primary text-uppercase mb-1">
                        <small class="font-weight-bold">Total Orders</small>
                    </div>
                    <h3 class="h3 mb-0">@ViewBag.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-success text-uppercase mb-1">
                        <small class="font-weight-bold">Total Revenue</small>
                    </div>
                    <h3 class="h3 mb-0">Rs. @ViewBag.TotalRevenue.ToString("F2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-info text-uppercase mb-1">
                        <small class="font-weight-bold">Total Customers</small>
                    </div>
                    <h3 class="h3 mb-0">@ViewBag.TotalCustomers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-warning text-uppercase mb-1">
                        <small class="font-weight-bold">Total Products</small>
                    </div>
                    <h3 class="h3 mb-0">@ViewBag.TotalProducts</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Box for Low Stock -->
    @if (ViewBag.LowStockProducts > 0)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Attention!</strong> You have @ViewBag.LowStockProducts product(s) with low stock. 
            <a href="@Url.Action("StockReport", "Admin")" class="alert-link">View Stock Report</a>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="row">
        <!-- Quick Links -->
        <div class="col-md-12">
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white">
                    <h6 class="mb-0"><i class="fas fa-link"></i> Quick Links</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <a href="@Url.Action("StockReport", "Admin")" class="btn btn-block btn-outline-success btn-lg">
                                <i class="fas fa-box-open"></i>
                                <br />
                                <span>Stock Report</span>
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="@Url.Action("OrderReport", "Admin")" class="btn btn-block btn-outline-primary btn-lg">
                                <i class="fas fa-shopping-cart"></i>
                                <br />
                                <span>Order Report</span>
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="@Url.Action("Index", "AdmItems")" class="btn btn-block btn-outline-info btn-lg">
                                <i class="fas fa-cube"></i>
                                <br />
                                <span>Manage Items</span>
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="@Url.Action("Index", "AdmCategories")" class="btn btn-block btn-outline-warning btn-lg">
                                <i class="fas fa-list"></i>
                                <br />
                                <span>Manage Categories</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Dashboard Info Cards -->
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="fas fa-chart-bar"></i> Stock Overview</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label>Total Products</label>
                            <span class="badge badge-primary">@ViewBag.TotalProducts</span>
                        </div>
                        <small class="text-muted">All products in inventory</small>
                    </div>
                    <hr />
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label>Low Stock Products</label>
                            <span class="badge badge-warning">@ViewBag.LowStockProducts</span>
                        </div>
                        <small class="text-muted">Products with stock less than 10 units</small>
                    </div>
                    <hr class="mb-0" />
                    <div class="pt-3">
                        <a href="@Url.Action("StockReport", "Admin")" class="btn btn-sm btn-info btn-block">
                            <i class="fas fa-arrow-right"></i> View Full Report
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="fas fa-coins"></i> Sales Overview</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label>Total Revenue</label>
                            <span class="badge badge-success">Rs. @ViewBag.TotalRevenue.ToString("F2")</span>
                        </div>
                        <small class="text-muted">All time revenue from orders</small>
                    </div>
                    <hr />
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label>Total Orders</label>
                            <span class="badge badge-info">@ViewBag.TotalOrders</span>
                        </div>
                        <small class="text-muted">Total customer orders</small>
                    </div>
                    <hr class="mb-0" />
                    <div class="pt-3">
                        <a href="@Url.Action("OrderReport", "Admin")" class="btn btn-sm btn-success btn-block">
                            <i class="fas fa-arrow-right"></i> View Full Report
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #007bff !important;
    }

    .border-left-success {
        border-left: 0.25rem solid #28a745 !important;
    }

    .border-left-info {
        border-left: 0.25rem solid #17a2b8 !important;
    }

    .border-left-warning {
        border-left: 0.25rem solid #ffc107 !important;
    }

    .card {
        border: none;
    }

    .card-body {
        padding: 1.5rem;
    }

    .font-weight-bold {
        font-weight: 600;
    }

    .btn-block {
        display: block;
        width: 100%;
    }

    .btn-lg {
        padding: 1.5rem;
        font-size: 1rem;
    }

    .btn-outline-success:hover,
    .btn-outline-primary:hover,
    .btn-outline-info:hover,
    .btn-outline-warning:hover {
        color: white;
    }

    .btn i {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .badge {
        padding: 0.5rem 0.75rem;
    }
</style>
