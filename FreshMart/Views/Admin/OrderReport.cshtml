@using FreshMart.Controllers
@model List<OrderReportData>

@{
    ViewData["Title"] = "Order Report";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="mb-1">
                <i class="fas fa-shopping-cart text-primary"></i> Order Report
            </h1>
            <small class="text-muted">Track and analyze all customer orders</small>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-primary text-uppercase mb-1">
                        <small class="font-weight-bold">Total Orders</small>
                    </div>
                    <h3 class="h3 mb-0">@ViewBag.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-success text-uppercase mb-1">
                        <small class="font-weight-bold">Total Revenue</small>
                    </div>
                    <h3 class="h3 mb-0">Rs. @ViewBag.TotalRevenue.ToString("F2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-info text-uppercase mb-1">
                        <small class="font-weight-bold">Average Order Value</small>
                    </div>
                    <h3 class="h3 mb-0">Rs. @ViewBag.AverageOrderValue.ToString("F2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-warning text-uppercase mb-1">
                        <small class="font-weight-bold">Order Count</small>
                    </div>
                    <h3 class="h3 mb-0">@Model?.Count() ?? 0</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters and Search -->
    <div class="row mb-3">
        <div class="col-md-6">
            <form method="get" action="@Url.Action("OrderReport", "Admin")">
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control" 
                           placeholder="Search by customer name, email, or order ID..." 
                           value="@ViewBag.SearchTerm">
                    <div class="input-group-append">
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
        <div class="col-md-3">
            <form method="get" action="@Url.Action("OrderReport", "Admin")" class="form-inline w-100">
                <select name="filterBy" class="form-control w-100" onchange="this.form.submit()">
                    @if (ViewBag.FilterBy == "all")
                    {
                        <option value="all" selected>All Orders</option>
                    }
                    else
                    {
                        <option value="all">All Orders</option>
                    }
                    @if (ViewBag.FilterBy == "today")
                    {
                        <option value="today" selected>Today</option>
                    }
                    else
                    {
                        <option value="today">Today</option>
                    }
                    @if (ViewBag.FilterBy == "week")
                    {
                        <option value="week" selected>Last 7 Days</option>
                    }
                    else
                    {
                        <option value="week">Last 7 Days</option>
                    }
                    @if (ViewBag.FilterBy == "month")
                    {
                        <option value="month" selected>This Month</option>
                    }
                    else
                    {
                        <option value="month">This Month</option>
                    }
                </select>
                <input type="hidden" name="searchTerm" value="@ViewBag.SearchTerm">
            </form>
        </div>
        <div class="col-md-3 text-right">
            <a href="@Url.Action("ExportOrderReport", "Admin")" class="btn btn-success">
                <i class="fas fa-download"></i> Export CSV
            </a>
        </div>
    </div>

    <!-- Order Report Table -->
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h6 class="mb-0"><i class="fas fa-table"></i> Order Details</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-bottom">Order ID</th>
                            <th class="border-bottom">Order Date</th>
                            <th class="border-bottom">Customer Name</th>
                            <th class="border-bottom">Email</th>
                            <th class="border-bottom">Phone</th>
                            <th class="border-bottom">Items Count</th>
                            <th class="border-bottom">Total Amount</th>
                            <th class="border-bottom">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count() > 0)
                        {
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge badge-primary">ORD-@order.OrderId</span>
                                    </td>
                                    <td>
                                        <strong>@order.OrderDate.ToString("dd MMM yyyy")</strong>
                                        <br />
                                        <small class="text-muted">@order.OrderDate.ToString("hh:mm tt")</small>
                                    </td>
                                    <td>
                                        <strong>@order.CustomerName</strong>
                                    </td>
                                    <td>
                                        <small>@order.CustomerEmail</small>
                                    </td>
                                    <td>
                                        <small>@order.CustomerPhone</small>
                                    </td>
                                    <td>
                                        <span class="badge badge-info">@order.ItemCount items</span>
                                    </td>
                                    <td>
                                        <h6 class="text-success mb-0">Rs. @order.TotalAmount.ToString("F2")</h6>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("OrderDetails", "Admin", new { id = order.OrderId })" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    <i class="fas fa-inbox text-muted" style="font-size: 2rem;"></i>
                                    <p class="mt-2 text-muted">No orders found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #007bff !important;
    }

    .border-left-success {
        border-left: 0.25rem solid #28a745 !important;
    }

    .border-left-info {
        border-left: 0.25rem solid #17a2b8 !important;
    }

    .border-left-warning {
        border-left: 0.25rem solid #ffc107 !important;
    }

    .card-body {
        padding: 1.5rem;
    }

    .font-weight-bold {
        font-weight: 600;
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    .btn-outline-primary:hover {
        background-color: #007bff;
        color: white;
    }
</style>
