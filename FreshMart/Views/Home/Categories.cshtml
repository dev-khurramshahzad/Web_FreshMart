@model IEnumerable<FreshMart.Models.Category>


<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">All Categories</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="/Home/">Home</a></li>
        <li class="breadcrumb-item active text-white">Categories</li>
    </ol>
</div>
<!-- Single Page Header End -->


<!-- Featurs Start -->
<div class="container-fluid service py-5">
    <div class="container py-5">
        <div class="row g-4 justify-content-center">
            @foreach (var category in Model)
            {
                <div class="col-md-4 col-lg-4">
                    <a href="/Home/Items/@category.CategoryId">
                        <div class="service-item bg-secondary rounded border border-secondary">
                            <img src="/Users/img/featur-1.jpg" class="img-fluid rounded-top w-100" alt="">
                            <div class="px-4 rounded-bottom">
                                <div class="service-content bg-primary text-center p-4 rounded">
                                    <h5 class="text-white">@category.CategoryName</h5>
                                    <h3 class="mb-0">@category.CategoryStatus</h3>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }

            
          
        </div>
    </div>
</div>
<!-- Featurs End -->