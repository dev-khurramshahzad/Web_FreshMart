@model FreshMart.Models.Order

@{
    ViewData["Title"] = "Invoice";
    decimal grandTotal = Model.TotalAmount ?? 0;
}


<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Order Confirmed</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="#">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Pages</a></li>
        <li class="breadcrumb-item active text-white">Cart</li>
    </ol>
</div>
<!-- Single Page Header End -->
<!-- Cart Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        
       

        <div class="container mt-5">

            <div class="card shadow p-4">

                <div class="text-center mb-4">
                    <h2>FreshMart Invoice</h2>
                    <hr />
                </div>

                <div class="row mb-4">

                    <div class="col-md-6">
                        <h5>Order Information</h5>

                        <p>
                            <strong>Order ID:</strong>
                            @Model.OrderId
                        </p>

                        <p>
                            <strong>Order Date:</strong>
                            @Model.OrderDate
                        </p>

                        <p>
                            <strong>Customer Name:</strong>
                            @Model.CustomerF?.FullName
                        </p>
                        <p>
                            <strong>Customer Phone:</strong>
                            @Model.CustomerF?.Phone
                        </p>
                        <p>
                            <strong>Customer Addess:</strong>
                            @Model.CustomerF?.Address
                        </p>
                    </div>

                </div>

                <table class="table table-bordered table-hover">

                    <thead class="table-dark">
                        <tr>
                            <th>Item</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in ViewBag.OrderDetails)
                        {
                            decimal subtotal = (decimal)(item.UnitPrice * item.Quantity);

                            <tr>
                                <td>@item.ItemF.Name</td>
                                <td>@item.UnitPrice</td>
                                <td>@item.Quantity</td>
                                <td>@subtotal</td>
                            </tr>
                        }

                    </tbody>

                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">
                                Grand Total
                            </th>

                            <th>
                                Rs. @grandTotal
                            </th>
                        </tr>
                    </tfoot>

                </table>

                <div class="text-center mt-4">
                    <a href="/"class="btn btn-success">Continue Shopping</a>
                </div>

            </div>

        </div>
    </div>
</div>
<!-- Cart Page End -->